{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "shell:allow-execute",
    "store:default",
    "dialog:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "sg",
          "cmd": "sg",
          "args": [
            "scan",
            "--inline-rules",
            {
              "validator": "*"
            },
            "--json=compact"
          ]
        }
      ]
    }
  ]
}